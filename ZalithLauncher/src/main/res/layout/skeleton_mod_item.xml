<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/_120sdp"
    android:background="@drawable/background_item"
    android:padding="@dimen/_8sdp">

    <!-- Shimmer effect for thumbnail -->
    <View
        android:id="@+id/skeleton_thumbnail"
        android:layout_width="@dimen/_54sdp"
        android:layout_height="@dimen/_54sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Shimmer effect for title -->
    <View
        android:id="@+id/skeleton_title"
        android:layout_width="0dp"
        android:layout_height="@dimen/_14sdp"
        android:layout_marginStart="@dimen/_8sdp"
        android:layout_marginEnd="@dimen/_60sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintStart_toEndOf="@id/skeleton_thumbnail"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Shimmer effect for platform badge -->
    <View
        android:id="@+id/skeleton_platform"
        android:layout_width="@dimen/_50sdp"
        android:layout_height="@dimen/_12sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Shimmer effect for category -->
    <View
        android:id="@+id/skeleton_category"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_12sdp"
        android:layout_marginTop="@dimen/_4sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintStart_toStartOf="@id/skeleton_title"
        app:layout_constraintTop_toBottomOf="@id/skeleton_title" />

    <!-- Shimmer effect for description line 1 -->
    <View
        android:id="@+id/skeleton_desc1"
        android:layout_width="0dp"
        android:layout_height="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_4sdp"
        android:layout_marginEnd="@dimen/_20sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintStart_toStartOf="@id/skeleton_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeleton_category" />

    <!-- Shimmer effect for description line 2 -->
    <View
        android:id="@+id/skeleton_desc2"
        android:layout_width="0dp"
        android:layout_height="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_2sdp"
        android:layout_marginEnd="@dimen/_80sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintStart_toStartOf="@id/skeleton_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeleton_desc1" />

    <!-- Shimmer effect for tags -->
    <View
        android:id="@+id/skeleton_tag1"
        android:layout_width="@dimen/_70sdp"
        android:layout_height="@dimen/_12sdp"
        android:layout_marginTop="@dimen/_4sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintStart_toStartOf="@id/skeleton_title"
        app:layout_constraintTop_toBottomOf="@id/skeleton_desc2" />

    <View
        android:id="@+id/skeleton_tag2"
        android:layout_width="@dimen/_60sdp"
        android:layout_height="@dimen/_12sdp"
        android:layout_marginStart="@dimen/_4sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintStart_toEndOf="@id/skeleton_tag1"
        app:layout_constraintTop_toTopOf="@id/skeleton_tag1" />

    <View
        android:id="@+id/skeleton_tag3"
        android:layout_width="@dimen/_50sdp"
        android:layout_height="@dimen/_12sdp"
        android:layout_marginStart="@dimen/_4sdp"
        android:background="@color/background_menu_element"
        android:alpha="0.3"
        app:layout_constraintStart_toEndOf="@id/skeleton_tag2"
        app:layout_constraintTop_toTopOf="@id/skeleton_tag1" />

</androidx.constraintlayout.widget.ConstraintLayout>
