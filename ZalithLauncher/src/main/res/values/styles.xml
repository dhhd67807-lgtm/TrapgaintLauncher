<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@style/Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <!-- Apply Bebas Neue font to entire app -->
        <item name="android:fontFamily">@font/bebas_neue_regular</item>
        <item name="fontFamily">@font/bebas_neue_regular</item>
        <item name="android:textColor">@color/primary_text</item>
    </style>

    <style name="CustomDialogStyle" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
    </style>

    <style name="CustomAlertDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
    </style>

    <style name="RoundedCornersImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4%</item>
    </style>

    <style name="RoundImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Splash Screen Theme - Simple theme without Android 12+ splash API -->
    <style name="SplashTheme" parent="AppTheme">
        <item name="android:windowBackground">@color/background_app</item>
    </style>
</resources>
